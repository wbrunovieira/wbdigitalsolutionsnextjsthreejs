# .env.example
# Copy this file to .env and fill in your values

# Web3 Forms Access Key for contact form
NEXT_PUBLIC_WEB3_FORMS_ACCESS_KEY=your-web3-forms-key-here

# API URL for chatbot backend (optional - chatbot will work in fallback mode if not configured)
# For local development: http://localhost:8000
# For production: https://your-api-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Sentry error monitoring (optional). Leave empty and Sentry stays fully inert.
# 1. Create a free project at sentry.io (Next.js). 2. Add these on Vercel.
NEXT_PUBLIC_SENTRY_DSN=
# Only needed to upload source maps at build time (nicer stack traces):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=